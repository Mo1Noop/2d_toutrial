[sub_resource type="GDScript" id="GDScript_vb1bs"]
script/source = "extends Button

@export var particles_settings : Hit_Particle_Settings
const SPIKE_DOMMY = preload(\"uid://pm005prnlt1u\")
func _ready() -> void:
	pressed.connect( _on_pressed )
	

func _on_pressed() -> void:
	var player_pos : Vector2 = get_tree().get_first_node_in_group( \"Player\" ).global_position
	var g := SPIKE_DOMMY.instantiate()
	owner.add_child(g)
	g.global_position = player_pos
	
	#VisualEffects.hit_particles( player_pos, Vector2(0,-1), particles_settings )
	#VisualEffects.camera_chake( 50.0 )
	
"

